DATABASE_URL=postgres://<username>:<password>@localhost:5432/recomdash&schema=public
SESSION_SECRET=
SEED_ACCOUNT_PASSWORD=

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis configuration
REDIS_USERNAME=default
REDIS_PASSWORD=redis_password
REDIS_HOST=redis-host
REDIS_PORT=12509
REDIS_ADDR=redis-host:12509
REDIS_DB=0
REDIS_URL=

# Gemini configuration
GEMINI_API_KEY=

# Order generator (scripts/order-generator.ts)
GENERATOR_EMAIL=admin@example.com
GENERATOR_PASSWORD=

# Go realtime service (used by the React frontend)
REDWOOD_ENV_GO_SERVICE_URL=http://localhost:8080
REDWOOD_ENV_GO_SERVICE_WS_URL=ws://localhost:8080
GENERATOR_API_URL=http://localhost:8911

# Go service bootstrap — internal Redwood API URL used by the Go service
# to fetch the DB baseline on startup when Redis holds no projection.
# Must point to the Redwood API port (default 8911), not the frontend.
# In production Docker Compose this is overridden to:
#   http://redwood-api:8911/.redwood/functions
BOOTSTRAP_API_URL=http://localhost:8911

# ── Production / Docker Hub (CI/CD) ─────────────────────────────────────────
# Docker Hub credentials — set as GitHub Actions secrets, not here.
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=

# EC2 SSH — set as GitHub Actions secrets, not here.
# EC2_HOST=
# EC2_USER=ubuntu
# EC2_SSH_KEY=  (full PEM private key)

# Docker Compose image tag (defaults to 'latest' if unset)
TAG=latest
